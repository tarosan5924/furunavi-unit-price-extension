{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["chrome", "node"],
    "lib": ["ES2022", "DOM"]
  },
  "include": ["src/**/*", "tests/**/*", "scripts/**/*", "vite.config.ts", "vitest.config.ts"]
}
